@model IEnumerable<TechMovePrototype.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
}

<h2>Service Requests</h2>

<table class="table table-striped table-hover">
    <thead class="table-dark">
        <tr>
            <th>Contract</th>
            <th>Description</th>
            <th>USD Amount</th>
            <th>ZAR Cost</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Contract?.Client?.Name - @item.Contract?.ServiceLevel</td>
                <td>@item.Description</td>
                <td>@item.USDValue.ToString("C2", System.Globalization.CultureInfo.GetCultureInfo("en-US"))</td>
                <td><strong>ZAR</strong> @item.ZARCost.ToString("N2")</td>
                <td>
                    <span class="badge bg-@(item.Status == TechMovePrototype.Models.Enums.ServiceRequestStatus.Completed ? "success" :
                                               item.Status == TechMovePrototype.Models.Enums.ServiceRequestStatus.InProgress ? "primary" :
                                               item.Status == TechMovePrototype.Models.Enums.ServiceRequestStatus.Rejected ? "danger" : "warning")">
                        @item.Status
                    </span>
                </td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-primary btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">No service requests found.</div>
}