<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TechMove Logistics</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TechMovePrototype.styles.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Barlow:wght@400;600;700;800&family=Barlow+Condensed:wght@700;800&display=swap" rel="stylesheet" />
</head>
<body>

    <header>
        <nav class="tm-navbar">
            <div class="container-fluid tm-nav-inner">

                <a class="tm-brand" asp-area="" asp-controller="Home" asp-action="Index">
                 
                    <span class="tm-brand-text">TechMove <span class="tm-brand-accent">Logistics</span></span>
                </a>

                <ul class="tm-nav-links ms-auto">
                    <li>
                        <a asp-controller="Home" asp-action="Index" class="tm-nav-link">Home</a>
                    </li>
                    <li>
                        <a asp-controller="Clients" asp-action="Index" class="tm-nav-link">Clients</a>
                    </li>
                    <li>
                        <a asp-controller="Contracts" asp-action="Index" class="tm-nav-link">Contracts</a>
                    </li>
                    <li>
                        <a asp-controller="ServiceRequests" asp-action="Index" class="tm-nav-link">Service Requests</a>
                    </li>
                </ul>

            </div>
        </nav>
    </header>

    @* Hero banner only shows on the Home page *@
    @if (ViewData["Title"]?.ToString() == "Home Page")
    {
        <section class="tm-hero">
            <div class="tm-hero-overlay"></div>
            <div class="container tm-hero-content">
                <p class="tm-hero-eyebrow">Global Logistics Management System</p>
                <h1 class="tm-hero-heading">
                  welcome to<br />
                    <span class="tm-hero-accent"> global logistics management system.</span>
                </h1>
             
                <div class="tm-hero-actions">
                    <a asp-controller="Contracts" asp-action="Index" class="tm-btn-primary">View Contracts</a>
                    <a asp-controller="Clients" asp-action="Index" class="tm-btn-ghost">Manage Clients</a>
                </div>
            </div>
        </section>
    }

    <div class="container tm-page-content">
        @if (TempData["Success"] != null)
        {
            <div class="tm-alert tm-alert-success">
                <span>✓</span> @TempData["Success"]
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="tm-alert tm-alert-error">
                <span>✕</span> @TempData["Error"]
            </div>
        }
        <main role="main" class="pb-4">
            @RenderBody()
        </main>
    </div>

    <footer class="tm-footer">
        <div class="container tm-footer-inner">
            <span class="tm-footer-brand">TechMove Logistics</span>
          
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>