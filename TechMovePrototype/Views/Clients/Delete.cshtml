@model TechMovePrototype.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<h2>Delete Client</h2>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this client?</strong>
    This will also delete all their contracts and service requests.
</div>

<div class="card p-4 mb-4" style="max-width: 500px;">
    <dl class="row">
        <dt class="col-sm-4">Name</dt>
        <dd class="col-sm-8">@Model.Name</dd>

        <dt class="col-sm-4">Email</dt>
        <dd class="col-sm-8">@Model.ContactEmail</dd>

        <dt class="col-sm-4">Phone</dt>
        <dd class="col-sm-8">@Model.ContactPhone</dd>

        <dt class="col-sm-4">Region</dt>
        <dd class="col-sm-8">@Model.Region</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>