@model TechMovePrototype.Models.Contract

<h2>Contract Details</h2>

<div class="card mb-4">
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Client</dt>
            <dd class="col-sm-9">@Model.Client?.Name</dd>

            <dt class="col-sm-3">Period</dt>
            <dd class="col-sm-9">@Model.StartDate.ToShortDateString() — @Model.EndDate.ToShortDateString()</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">
                <span class="badge bg-@(Model.Status == TechMovePrototype.Models.Enums.ContractStatus.Active ? "success" : Model.Status == TechMovePrototype.Models.Enums.ContractStatus.Expired ? "danger" : "warning") fs-6">
                    @Model.Status
                </span>
            </dd>

            <dt class="col-sm-3">Service Level</dt>
            <dd class="col-sm-9">@Model.ServiceLevel</dd>

            @if (!string.IsNullOrEmpty(Model.SignedAgreementFilePath))
            {
                <dt class="col-sm-3">Signed Agreement</dt>
                <dd class="col-sm-9">
                    <a asp-action="DownloadAgreement" asp-route-id="@Model.Id" class="btn btn-success btn-sm">
                        📄 Download PDF
                    </a>
                </dd>
            }
        </dl>
    </div>
</div>

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Edit Contract</a>

    @if (Model.Status == TechMovePrototype.Models.Enums.ContractStatus.Active)
    {
        <a asp-controller="ServiceRequests" asp-action="Create" asp-route-contractId="@Model.Id"
           class="btn btn-success">+ Create Service Request</a>
    }
    else
    {
        <button class="btn btn-secondary" disabled title="Only Active contracts allow new Service Requests">
            + Create Service Request (Contract must be Active)
        </button>
    }

    <a asp-action="Index" class="btn btn-secondary">Back to Contracts</a>
</div>