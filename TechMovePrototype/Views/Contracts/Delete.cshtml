@model TechMovePrototype.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>

<div class="alert alert-danger">
    <strong>Are you sure you want to delete this contract?</strong>
    This will also delete all linked service requests.
</div>

<div class="card p-4 mb-4" style="max-width: 500px;">
    <dl class="row">
        <dt class="col-sm-4">Client</dt>
        <dd class="col-sm-8">@Model.Client?.Name</dd>

        <dt class="col-sm-4">Start Date</dt>
        <dd class="col-sm-8">@Model.StartDate.ToShortDateString()</dd>

        <dt class="col-sm-4">End Date</dt>
        <dd class="col-sm-8">@Model.EndDate.ToShortDateString()</dd>

        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">@Model.Status</dd>

        <dt class="col-sm-4">Service Level</dt>
        <dd class="col-sm-8">@Model.ServiceLevel</dd>
    </dl>
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>